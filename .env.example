# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# === Qdrant ===
QDRANT_URL=https://your-qdrant-instance:6333
QDRANT_API_KEY=your-qdrant-api-key

# Collection names (optional, defaults work)
QDRANT_DIABETES_COLLECTION=diabetes_knowledge
QDRANT_BP_COLLECTION=blood_pressure_knowledge
QDRANT_GLANDS_COLLECTION=glands_knowledge

# === Gemini AI ===
GEMINI_API_KEY=your-gemini-api-key

# === Email (choose one provider) ===
EMAIL_PROVIDER=resend          # "resend" or "sendgrid"
RESEND_API_KEY=re_your_api_key
SENDGRID_API_KEY=SG.your_api_key
FROM_EMAIL=noreply@rafiq.app

# === App Settings ===
APP_ENV=development
SECRET_KEY=your-super-secret-jwt-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
